import pandas as pd
import sqlite3
 
# ── Sample Data ────────────────────────────────────────────────────────────────
data = {
    "age":     [37, 18, 23, 32, 58],
    "sex":     ["male", "male", "female", "male", "female"],
    "bmi":     [34.10, 34.43, 36.67, 35.20, 32.395],
    "children":[4, 0, 2, 2, 1],
    "smoker":  ["yes", "no", "yes", "no", "no"],
    "region":  ["southwest", "southeast", "northeast", "southwest", "northeast"],
    "charges": [40182.246, 1137.4697, 38511.6283, 4670.64, 13019.16105],
}
 
df = pd.DataFrame(data)
 
# ── Build Dimension Tables ─────────────────────────────────────────────────────
 
# DIM_PERSON — unique combo of demographic attributes
dim_person = (
    df[["age", "sex", "bmi", "children"]]
    .drop_duplicates()
    .reset_index(drop=True)
)
dim_person.index += 1
dim_person.index.name = "person_id"
dim_person = dim_person.reset_index()
 
# DIM_REGION
dim_region = (
    df[["region"]]
    .drop_duplicates()
    .rename(columns={"region": "region_name"})
    .reset_index(drop=True)
)
dim_region.index += 1
dim_region.index.name = "region_id"
dim_region = dim_region.reset_index()
 
# DIM_SMOKER
dim_smoker = (
    df[["smoker"]]
    .drop_duplicates()
    .rename(columns={"smoker": "smoker_status"})
    .reset_index(drop=True)
)
dim_smoker.index += 1
dim_smoker.index.name = "smoker_id"
dim_smoker = dim_smoker.reset_index()
 
# ── Build Fact Table ───────────────────────────────────────────────────────────
fact = df.copy()
 
# Join FK: person_id
fact = fact.merge(dim_person, on=["age", "sex", "bmi", "children"], how="left")
 
# Join FK: region_id
fact = fact.merge(
    dim_region.rename(columns={"region_name": "region"}),
    on="region", how="left"
)
 
# Join FK: smoker_id
fact = fact.merge(
    dim_smoker.rename(columns={"smoker_status": "smoker"}),
    on="smoker", how="left"
)
 
# Keep only fact columns
fact_insurance = fact[["person_id", "region_id", "smoker_id", "charges"]].copy()
fact_insurance.index += 1
fact_insurance.index.name = "charge_id"
fact_insurance = fact_insurance.reset_index()
 
# ── Preview ────────────────────────────────────────────────────────────────────
print("=" * 55)
print("DIM_PERSON")
print("=" * 55)
print(dim_person.to_string(index=False))
 
print("\n" + "=" * 55)
print("DIM_REGION")
print("=" * 55)
print(dim_region.to_string(index=False))
 
print("\n" + "=" * 55)
print("DIM_SMOKER")
print("=" * 55)
print(dim_smoker.to_string(index=False))
 
print("\n" + "=" * 55)
print("FACT_INSURANCE")
print("=" * 55)
print(fact_insurance.to_string(index=False))
 
# ── Load into SQLite ───────────────────────────────────────────────────────────
conn = sqlite3.connect("star_schema.db")
cursor = conn.cursor()
 
# Drop tables if they exist (for reruns)
for tbl in ["FACT_INSURANCE", "DIM_PERSON", "DIM_REGION", "DIM_SMOKER"]:
    cursor.execute(f"DROP TABLE IF EXISTS {tbl}")
 
# Create dimension tables
cursor.execute("""
    CREATE TABLE DIM_PERSON (
        person_id INTEGER PRIMARY KEY,
        age       INTEGER,
        sex       VARCHAR(10),
        bmi       DECIMAL(5,2),
        children  INTEGER
    )
""")
 
cursor.execute("""
    CREATE TABLE DIM_REGION (
        region_id   INTEGER PRIMARY KEY,
        region_name VARCHAR(20)
    )
""")
 
cursor.execute("""
    CREATE TABLE DIM_SMOKER (
        smoker_id     INTEGER PRIMARY KEY,
        smoker_status VARCHAR(3)
    )
""")
 
# Create fact table with foreign keys
cursor.execute("""
    CREATE TABLE FACT_INSURANCE (
        charge_id INTEGER PRIMARY KEY,
        person_id INTEGER,
        region_id INTEGER,
        smoker_id INTEGER,
        charges   DECIMAL(10,4),
        FOREIGN KEY (person_id) REFERENCES DIM_PERSON(person_id),
        FOREIGN KEY (region_id) REFERENCES DIM_REGION(region_id),
        FOREIGN KEY (smoker_id) REFERENCES DIM_SMOKER(smoker_id)
    )
""")
 
# Insert data
dim_person.to_sql("DIM_PERSON",     conn, if_exists="append", index=False)
dim_region.to_sql("DIM_REGION",     conn, if_exists="append", index=False)
dim_smoker.to_sql("DIM_SMOKER",     conn, if_exists="append", index=False)
fact_insurance.to_sql("FACT_INSURANCE", conn, if_exists="append", index=False)
 
conn.commit()
 
# ── Sample Query: Rejoin to verify ─────────────────────────────────────────────
print("\n" + "=" * 55)
print("SAMPLE QUERY — Rejoined Star Schema")
print("=" * 55)
 
query = """
    SELECT
        f.charge_id,
        p.age,
        p.sex,
        p.bmi,
        p.children,
        r.region_name,
        s.smoker_status,
        f.charges
    FROM FACT_INSURANCE f
    JOIN DIM_PERSON p ON f.person_id = p.person_id
    JOIN DIM_REGION r ON f.region_id = r.region_id
    JOIN DIM_SMOKER s ON f.smoker_id = s.smoker_id
"""
 
result = pd.read_sql_query(query, conn)
print(result.to_string(index=False))
 
conn.close()
print("\nDatabase saved to: star_schema.db")
 



